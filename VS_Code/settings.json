{
    "//": "Tabs",
      "editor.tabSize": 2,
      "editor.insertSpaces": false,
    "//": "Remove highlighting of occurrences of currently selected word",
      "editor.occurrencesHighlight": "off",
    "//": "No editor/welcome file on startup.",
      "workbench.startupEditor": "none",
    "//": "Removes startup prompt related to workspace trust.",
      "security.workspace.trust.startupPrompt": "never",
      "security.workspace.trust.banner": "never",
      "security.workspace.trust.untrustedFiles": "open",
    "//": "Default terminal shell",
      "terminal.integrated.defaultProfile.linux": "bash",
    "//": "Remove minimap",
      "editor.minimap.enabled": false,
    "//": "Remove indentation guides",
      "editor.guides.indentation": false,
    "//": "Remove bracket pair hightlighting",
      "editor.guides.bracketPairsHorizontal": false,
    "//": "Setting up priter",
      "editor.defaultFormatter": "esbenp.prettier-vscode",
      "[javascript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
      },
      "[markdown]": {
        "editor.defaultFormatter": "darkriszty.markdown-table-prettify"
      },
      "window.restoreFullscreen": true,
      "svg.preview.mode": "svg",
      "window.newWindowDimensions": "maximized",
      "diffEditor.ignoreTrimWhitespace": false,
      "editor.stickyScroll.enabled": false,
      "extensions.experimental.affinity": {
        "asvetliakov.vscode-neovim": 1
      },
      "editor.rulers": [
        80
      ],
      "markdown-toc.depthFrom": 2,
      "C_Cpp.configurationWarnings": "disabled",
      "makefile.configureOnOpen": true,
      "workbench.iconTheme": "material-icon-theme",
      "vscode-neovim.ctrlKeysForNormalMode": [
        "a",
        "b",
        "c",
        "d",
        "e",
        "f",
        "h",
        "i",
        "j",
        "k",
        "l",
        "m",
        "o",
        "r",
        "t",
        "u",
        "v",
        "x",
        "y",
        "z",
        "/",
        "]",
        "right",
        "left",
        "up",
        "down",
        "backspace",
        "delete",
        "w"
      ],
      "workbench.colorTheme": "Default Dark+",
      "workbench.colorCustomizations": {
        "editor.background": "#000000",
        "sideBar.background": "#000000",
        "terminal.background": "#000000",
        "activityBar.background": "#000000"
      },
      "window.title": "${rootName}",
      "chat.commandCenter.enabled": false,
      "editor.wordWrap": "on",
      "markdown-toc.orderedList": false,
      "markdown.preview.scrollEditorWithPreview": false,
      "markdown.preview.scrollPreviewWithEditor": false,
      "cmake.ignoreCMakeListsMissing": true,
      "cSpell.userWords": [
        "consentual"
      ],
      "cmake.additionalKits": [
        "/usr/bin/arm-none-eabi-gcc"
      ],
      "cmake.environment": {
        "PATH": "/home/ryan/.vscode/extensions/stmicroelectronics.stm32cube-ide-core-1.2.1-linux-x64/resources/binaries/linux/x86_64:/home/ryan/.vscode/extensions/stmicroelectronics.stm32cube-ide-build-cmake-1.44.0-linux-x64/resources/cube-cmake/linux/x86_64:${env.PATH}"
      },
      "stm32cube-ide-clangd.detectExtensionConflicts": false,
      "stm32cube-ide-core.configuration.productSTM32CubeMX.executablePath": "/home/ryan/STM32CubeMX/jre/bin/java -jar /home/ryan/STM32CubeMX/STM32CubeMX",
      "stm32cube-ide-build-cmake.ignoreCubeProjectDiscovery": false,
      "cmake.cmakePath": "cube-cmake",
      "debug.allowBreakpointsEverywhere": true,
      "cSpell.maxNumberOfProblems": 10000,
      "cSpell.diagnosticLevelFlaggedWords": "Warning",
      "cSpell.diagnosticLevel": "Warning",
  }